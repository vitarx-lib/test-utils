{
  "name": "@vitarx/test-utils",
  "version": "2.0.0-beta.1",
  "description": "A library of test tools designed specifically for the Vitarx framework",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "vitarx",
    "vitarx-test",
    "test-utils"
  ],
  "author": "zhuchonglin <8210856@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitarx-lib/test-utils.git"
  },
  "license": "MIT",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && vitest run && tsc -p tsconfig.build.json",
    "release": "release-cli",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vitarx": "^4.0.0-0"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@types/node": "^24.10.2",
    "@vitarx/plugin-vite": "^0.0.1-beta.4",
    "vitarx": "4.0.0-beta.6",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.2.7",
      "@vitarx/plugin-vite": "0.0.1-beta.4",
      "vitarx": "4.0.0-beta.6"
    }
  }
}
